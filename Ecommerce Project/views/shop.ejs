<%- include('./partials/header') %>

<main class="mx-auto max-w-7xl px-6 py-10">
    <div class="grid gap-10 lg:grid-cols-[260px_1fr]">
        <aside class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
            <div class="space-y-8">
                <div class="space-y-3">
                    <h2 class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">Sort by</h2>
                    <form action="/shop">
                        <select class="w-full rounded-3xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-700 outline-none" name="sortby" id="">
                            <option value="popular">Popular</option>
                            <option value="newest">Newest</option>
                        </select>
                    </form>
                </div>
                <div class="space-y-3">
                    <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Collections</h3>
                    <a class="block text-slate-700 transition hover:text-slate-900" href="">New Collection</a>
                    <a class="block text-slate-700 transition hover:text-slate-900" href="">All Products</a>
                    <a class="block text-slate-700 transition hover:text-slate-900" href="">Discounted Products</a>
                </div>
                <div class="space-y-3">
                    <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Filter by</h3>
                    <a class="block text-slate-700 transition hover:text-slate-900" href="">Availability</a>
                    <a class="block text-slate-700 transition hover:text-slate-900" href="">Discount</a>
                </div>
            </div>
        </aside>

        <section class="space-y-8">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <h1 class="text-3xl font-semibold">Shop</h1>
                    <p class="text-sm text-slate-500">Discover your next favorite item.</p>
                </div>
                <p class="text-sm text-slate-500"><%= products.length %> products</p>
            </div>

            <% if (products && products.length) { %>
                <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
                    <% products.forEach(function(product){ %>
                        <% let imgSrc = '/images/' + product.image;
                           if (typeof product.image === 'string' && (product.image.startsWith('data:') || product.image.startsWith('/') || product.image.startsWith('http'))) {
                               imgSrc = product.image;
                           }
                        %>
                        <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
                           <div class="aspect-[4/3] flex items-center justify-center" style="background-color:<%= product.bgcolor || '#f8fafc' %>">
                                <img class="max-h-56 object-contain" src="<%= imgSrc %>" alt="<%= product.name %>">
                            </div>
                            <div class="space-y-3 p-5" style="background-color:<%= product.panelcolor || '#ffffff' %>; color:<%= product.textcolor || '#0f172a' %>">
                                <div class="space-y-1">
                                    <h2 class="text-lg font-semibold"><%= product.name %></h2>
                                    <p class="text-sm">₹ <%= product.price %></p>
                                </div>
                                <a class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-white text-slate-900 shadow-sm transition hover:bg-slate-100" href="/addtocart/<%= product._id %>">
                                    <i class="ri-add-line text-xl"></i>
                                </a>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-10 text-center">
                    <h3 class="text-xl font-semibold mb-2">No products available</h3>
                    <p class="text-sm text-slate-500">Add products to the database or check your product-loading logic.</p>
                </div>
            <% } %>
        </section>
    </div>
</main>

<%- include('./partials/footer') %>